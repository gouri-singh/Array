// Bubble Sort
arr = [5,4,3,2,1]
n = len(arr)

print("Unsorted Array:", arr)

for i in range(len(arr)):
    for j in range(len(arr) - 1):

        if(arr[j] > arr[j+1]):
            arr[j], arr[j+1] = arr[j+1], arr[j]

print("Sorted Array:", arr)


// Reverse Array
arr = [1,2,10,5,7,4,11,15]
i = 0
j = len(arr) - 1

while(i <= j):
    arr[i], arr[j] = arr[j], arr[i] #swap
    i += 1
    j -=1

print("Reversed Array:", arr)


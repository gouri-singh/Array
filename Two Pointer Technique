// Pair Sum Search in Array using Two Pointer Technique 
arr = [1,2,10,5,7,3,11,15]
target = 16
left = 0
right = len(arr)-1

while(left < right):
    current_sum = arr[left] + arr[right]

    if(current_sum == target):
        print("Indexes:", left, right)
        print("Values:", arr[left], arr[right])
        break
    elif(current_sum < target):
        left += 1
    else:
        right -= 1

if(current_sum != target):
    print("Target Not Found:", target)


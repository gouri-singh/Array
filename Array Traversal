// Print OddSum & EvenSum of Array
arr = [1,3,2,6,5]
evensum = 0
oddsum = 0

for i in range(5):

    if(arr[i] % 2 == 0):
        evensum += arr[i]
    else:
        oddsum += arr[i]

print("Sum of odd number in given Array:", oddsum)
print("Sum of even number in given Array:", evensum)

